# ─── Supabase / Postgres ─────────────────────────────────────────────
# Desde el dashboard de Supabase → Project Settings → Database.
# DATABASE_URL: connection pooler (Transaction, puerto 6543) → usado por la app en runtime.
# DIRECT_URL:   conexión directa (puerto 5432)               → usado por Prisma para migraciones.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─── Supabase Auth (cliente) ─────────────────────────────────────────
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# ─── SMTP (correo diario del historial, vía Gmail) ───────────────────
# Gmail SMTP envía a cualquier destinatario sin necesitar un dominio verificado.
# SMTP_PASS es un "App Password" de Google (NO la clave normal): requiere 2FA activo →
# Cuenta Google → Seguridad → Verificación en 2 pasos → Contraseñas de aplicaciones.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="tu-cuenta@gmail.com"
SMTP_PASS="<app-password-de-16-caracteres>"
# Remitente (Gmail reescribe la dirección a SMTP_USER; el display name se respeta).
EMAIL_FROM="Pruff Propiedades <tu-cuenta@gmail.com>"
# Destinatarios del job diario (según el desafío).
EMAIL_TO="juanjose@pruff.com,ramiro.galvez@pruff.com"

# ─── Cron ────────────────────────────────────────────────────────────
# Secreto para proteger la route del cron (Vercel Cron manda este header).
CRON_SECRET="<random-string>"
