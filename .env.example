# ─── Supabase / Postgres ─────────────────────────────────────────────
# Desde el dashboard de Supabase → Project Settings → Database.
# DATABASE_URL: connection pooler (Transaction, puerto 6543) → usado por la app en runtime.
# DIRECT_URL:   conexión directa (puerto 5432)               → usado por Prisma para migraciones.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─── Supabase Auth (cliente) ─────────────────────────────────────────
# Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://<ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-key>"

# ─── Resend (correo diario del historial) ────────────────────────────
RESEND_API_KEY="re_..."
# Remitente verificado en Resend (dominio propio o onboarding@resend.dev para pruebas).
EMAIL_FROM="Pruff Propiedades <onboarding@resend.dev>"
# Destinatarios del job diario (según el desafío).
EMAIL_TO="juanjose@pruff.com,ramiro.galvez@pruff.com"

# ─── Cron ────────────────────────────────────────────────────────────
# Secreto para proteger la route del cron (Vercel Cron manda este header).
CRON_SECRET="<random-string>"
